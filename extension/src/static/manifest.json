{
  "name": "CortexTrack",
  "description": "AI Behavior Analyzer - Learn your digital patterns and detect behavioral changes",
  "version": "1.0.0",
  "manifest_version": 3,
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "CortexTrack",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "permissions": [
    "tabs",
    "idle",
    "storage",
    "alarms",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
